{
  "name": "@bubblebuffer/superpawers",
  "version": "0.4.3",
  "description": "Quick setup for SuperPawers skills and markdown agents for OpenCode",
  "bin": {
    "superpawers": "./dist/main.js"
  },
  "main": "./dist/main.js",
  "files": [
    "README.md",
    "dist/",
    "agents/",
    "skills/"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "node ./scripts/build.cjs",
    "cli:local": "npm run build && node ./dist/main.js",
    "smoke:package": "node ./scripts/smoke-package.cjs",
    "test": "vitest run",
    "prepack": "npm run build",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "jsonc-parser": "^3.3.1",
    "prompts": "^2.4.2"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/prompts": "^2.4.9",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  },
  "keywords": [
    "skills",
    "agents",
    "subagents",
    "coding-workflow"
  ],
  "author": "",
  "license": "MIT"
}
